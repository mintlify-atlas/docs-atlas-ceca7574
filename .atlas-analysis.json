    "Persistent shopping cart using Zustand and localStorage",
    "Stripe-powered checkout integration via external API",
    "Fully responsive design with Tailwind CSS",
    "Server-side data fetching with Next.js 13 App Router"
  ],
  "publicApiSurface": [
    "getProducts({ categoryId?, colorId?, sizeId?, isFeatured? })",
    "getProduct(id: string)",
    "getCategories()",
